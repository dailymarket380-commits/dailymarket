{
  "name": "dailymarket-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "business-portal"
  ],
  "scripts": {
    "dev:web": "npm run dev -w web",
    "dev:portal": "npm run dev -w business-portal",
    "build:web": "npm run build -w web",
    "build:portal": "npm run build -w business-portal",
    "install:all": "npm install && npm install -w web && npm install -w business-portal"
  }
}
